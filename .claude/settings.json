{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "magna-brain permission contract (v1.7). bypassPermissions mode + a deny list focused on system-level safety only. Architectural denies (writes to .claude/, tools/, .github/, CLAUDE.md, AGENTS.md, TOKEN_BUDGET.md, README.md, reference/) were removed in v1.7 so Sahil's architectural session can edit skills, the renderer, and the spec without per-file mv dances. Mehr's session is still constrained by CLAUDE.md prompt rules — the brain remains read-only in her session at the prompt layer even though the permission layer no longer enforces it. wiki/voice/ stays denied (hand-curated). All system-level destructive operations (rm, sudo, chmod, network, package installs, destructive git/gh, force push) remain denied for everyone. SessionStart hook silently pulls latest main.",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(./**)",
      "Read(//Users/**/magna-brain/**)",
      "Write(./raw/**)",
      "Write(./output/**)",
      "Write(./wiki/sources/**)",
      "Write(./wiki/entities/**)",
      "Write(./wiki/concepts/**)",
      "Write(./wiki/synthesis/**)",
      "Write(./wiki/_index/**)",
      "Write(./wiki/index.md)",
      "Write(./wiki/log.md)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(git add:*)",
      "Bash(git rm:*)",
      "Bash(git commit:*)",
      "Bash(git push:origin main)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git pull:*)",
      "Bash(git fetch:*)",
      "Bash(git show:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(date)",
      "Bash(python3:*)",
      "Bash(pdftotext:*)"
    ],
    "ask": [],
    "deny": [
      "Write(./wiki/voice/**)",
      "Edit(./wiki/voice/**)",

      "Bash(git push:*--force*)",
      "Bash(git push:*-f*)",
      "Bash(git push:origin main --force*)",
      "Bash(git reset:*--hard*)",
      "Bash(git rebase:*-i*)",
      "Bash(git branch:*-D*)",
      "Bash(git branch:*--delete*)",
      "Bash(git checkout:*--orphan*)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",

      "Bash(rm:*)",
      "Bash(rmdir:*)",

      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",

      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",

      "Bash(brew:*install*)",
      "Bash(brew:*uninstall*)",
      "Bash(npm:*install*)",
      "Bash(npm:*uninstall*)",
      "Bash(pip:*install*)",
      "Bash(pip3:*install*)",
      "Bash(pipx:*)",
      "Bash(gem:*install*)",
      "Bash(cargo:*install*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(dpkg:*)",

      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(terraform:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(az:*)",

      "Bash(gh auth:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo unarchive:*)",
      "Bash(gh secret:*)",
      "Bash(gh workflow:*)",
      "Bash(gh api:*DELETE*)",
      "Bash(gh api:*PATCH*)",
      "Bash(gh api:*PUT*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr delete:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" 2>/dev/null && git fetch origin main --quiet 2>/dev/null && [ -z \"$(git status --porcelain)\" ] && git pull --rebase --quiet origin main 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
