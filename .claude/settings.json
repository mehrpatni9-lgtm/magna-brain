{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Mehr-side permission contract for magna-brain. Do not edit without an architectural PR. See CLAUDE.md and AGENTS.md for the rationale. This file is enforced by Claude Code when Mehr opens the repo; it is NOT the contract for Sahil's terminal session, which operates from a separate settings.json outside this repo.",
  "permissions": {
    "allow": [
      "Read(//Users/mehr/magna-brain/**)",
      "Write(//Users/mehr/magna-brain/raw/**)",
      "Write(//Users/mehr/magna-brain/output/**)",
      "Bash(gh issue create:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:origin drafts/*)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git log:*)"
    ],
    "ask": [],
    "deny": [
      "Write(//Users/mehr/magna-brain/wiki/sources/**)",
      "Write(//Users/mehr/magna-brain/wiki/entities/**)",
      "Write(//Users/mehr/magna-brain/wiki/concepts/**)",
      "Write(//Users/mehr/magna-brain/wiki/synthesis/**)",
      "Write(//Users/mehr/magna-brain/wiki/voice/**)",
      "Write(//Users/mehr/magna-brain/wiki/index.md)",
      "Write(//Users/mehr/magna-brain/wiki/_index/**)",
      "Write(//Users/mehr/magna-brain/wiki/log.md)",
      "Write(//Users/mehr/magna-brain/.claude/**)",
      "Write(//Users/mehr/magna-brain/skills/**)",
      "Write(//Users/mehr/magna-brain/.github/**)",
      "Write(//Users/mehr/magna-brain/CLAUDE.md)",
      "Write(//Users/mehr/magna-brain/AGENTS.md)",
      "Write(//Users/mehr/magna-brain/TOKEN_BUDGET.md)",
      "Write(//Users/mehr/magna-brain/README.md)",
      "Bash(git push:origin main)",
      "Bash(git push:*--force*)",
      "Bash(git reset:*--hard*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*wiki/**)",
      "Bash(sudo:*)"
    ]
  }
}
