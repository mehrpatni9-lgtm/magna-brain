{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "magna-brain permission contract (v1.5). Mehr's session may write to raw/, output/, and the compiled layers of wiki/ (sources, entities, concepts, synthesis, log, index, _index) so the ingest skill can do a lightweight inline compile — turning her daily drops into structured brain articles. Hand-curated layers (wiki/voice/, CLAUDE.md, AGENTS.md, skills, workflows) stay denied so architectural changes still route through Sahil-merged PRs. Paths are project-relative; edit only via an architectural PR.",
  "permissions": {
    "allow": [
      "Read(./**)",
      "Read(//Users/**/magna-brain/**)",
      "Write(./raw/**)",
      "Write(./output/**)",
      "Write(./wiki/sources/**)",
      "Write(./wiki/entities/**)",
      "Write(./wiki/concepts/**)",
      "Write(./wiki/synthesis/**)",
      "Write(./wiki/_index/**)",
      "Write(./wiki/index.md)",
      "Write(./wiki/log.md)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:origin main)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git pull:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(date)",
      "Bash(python3:*tools/*)",
      "Bash(pdftotext:*)"
    ],
    "ask": [],
    "deny": [
      "Write(./wiki/voice/**)",
      "Write(./.claude/**)",
      "Write(./.github/**)",
      "Write(./CLAUDE.md)",
      "Write(./AGENTS.md)",
      "Write(./TOKEN_BUDGET.md)",
      "Write(./README.md)",
      "Write(./reference/**)",
      "Write(./tools/**)",
      "Bash(git push:*--force*)",
      "Bash(git reset:*--hard*)",
      "Bash(git rebase:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*wiki/voice/**)",
      "Bash(mv:*.claude/**)",
      "Bash(sudo:*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  }
}
