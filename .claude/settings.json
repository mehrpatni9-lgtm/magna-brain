{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "magna-brain permission contract (v1.5). Mehr's session runs in bypassPermissions mode so Claude never interrupts her with permission prompts — she gets a pure chat experience. The deny list still protects everything she shouldn't touch: wiki/voice/ (hand-curated), .claude/, .github/, CLAUDE.md, AGENTS.md, TOKEN_BUDGET.md, README.md, reference/, tools/, and any destructive shell operation. The allow list is kept for documentation; under bypassPermissions mode the deny list is what enforces safety. Edit this file ONLY via a Sahil-merged architectural PR.",
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Read(./**)",
      "Read(//Users/**/magna-brain/**)",
      "Write(./raw/**)",
      "Write(./output/**)",
      "Write(./wiki/sources/**)",
      "Write(./wiki/entities/**)",
      "Write(./wiki/concepts/**)",
      "Write(./wiki/synthesis/**)",
      "Write(./wiki/_index/**)",
      "Write(./wiki/index.md)",
      "Write(./wiki/log.md)",
      "Bash(gh issue create:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:origin main)",
      "Bash(git checkout:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git pull:*)",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(date)",
      "Bash(python3:*tools/*)",
      "Bash(pdftotext:*)"
    ],
    "ask": [],
    "deny": [
      "Write(./wiki/voice/**)",
      "Write(./.claude/**)",
      "Write(./.github/**)",
      "Write(./CLAUDE.md)",
      "Write(./AGENTS.md)",
      "Write(./TOKEN_BUDGET.md)",
      "Write(./README.md)",
      "Write(./reference/**)",
      "Write(./tools/**)",
      "Edit(./wiki/voice/**)",
      "Edit(./.claude/**)",
      "Edit(./.github/**)",
      "Edit(./CLAUDE.md)",
      "Edit(./AGENTS.md)",
      "Edit(./TOKEN_BUDGET.md)",
      "Edit(./README.md)",
      "Edit(./reference/**)",
      "Edit(./tools/**)",
      "Bash(git push:*--force*)",
      "Bash(git push:*-f*)",
      "Bash(git push:origin main --force*)",
      "Bash(git reset:*--hard*)",
      "Bash(git rebase:*)",
      "Bash(git branch:*-D*)",
      "Bash(git branch:*--delete*)",
      "Bash(git checkout:*--orphan*)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git update-ref:*)",
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*wiki/voice/**)",
      "Bash(mv:*.claude/**)",
      "Bash(mv:*.github/**)",
      "Bash(mv:*tools/**)",
      "Bash(mv:*CLAUDE.md*)",
      "Bash(mv:*AGENTS.md*)",
      "Bash(sudo:*)",
      "Bash(su:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(rsync:*)",
      "Bash(brew:*install*)",
      "Bash(brew:*uninstall*)",
      "Bash(npm:*install*)",
      "Bash(npm:*uninstall*)",
      "Bash(pip:*install*)",
      "Bash(pip3:*install*)",
      "Bash(pipx:*)",
      "Bash(gem:*install*)",
      "Bash(cargo:*install*)",
      "Bash(apt:*)",
      "Bash(apt-get:*)",
      "Bash(dpkg:*)",
      "Bash(docker:*)",
      "Bash(kubectl:*)",
      "Bash(terraform:*)",
      "Bash(gcloud:*)",
      "Bash(aws:*)",
      "Bash(az:*)",
      "Bash(gh auth:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo unarchive:*)",
      "Bash(gh secret:*)",
      "Bash(gh workflow:*)",
      "Bash(gh api:*DELETE*)",
      "Bash(gh api:*PATCH*)",
      "Bash(gh api:*PUT*)",
      "Bash(gh pr:*close*)",
      "Bash(gh pr:*delete*)"
    ]
  }
}
